# Copy this file to .env.local and fill in your key. .env.local is gitignored.
#
# Get a key at https://aistudio.google.com/apikey
# This is read ONLY by the server-side proxy (api/chat.js). It is never sent to
# the browser — do NOT rename it with a VITE_ prefix, or Vite will bundle it in.

GEMINI_API_KEY=your-key-here

# Optional — defaults to gemini-2.5-flash. Use gemini-flash-latest to always
# track the current flash model (Google retires older ones periodically).
# GEMINI_MODEL=gemini-2.5-flash
